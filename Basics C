#include <stdio.h> 
#include <limits.h>

int main () {
	
	printf("Ganze Zahlen\n");
	
	short sVar = 59;
	int iVar = 12; // 12 ist ein int Literal
	long lVar = 37L; // 37L ist ein long Literal
	long long llVar = -4LL;
	unsigned int uVar = -2000000000;
	
	printf("sVar = %i, Speicherbedarf %i Byte\n", sVar, sizeof(sVar));
	printf("iVar = %i, Speicherbedarf %i Byte\n", iVar, sizeof(iVar));
	printf("lVar = %li, Speicherbedarf %i Byte\n", lVar, sizeof(lVar));
	printf("llVar = %lli, Speicherbedarf %i Byte\n", llVar, sizeof(llVar));
	printf("uVar = %u, Speicherbedarf %i Byte\n", uVar, sizeof(uVar));



	printf("\nZeichen\n");
	char zeichen = 'a'; // ist signed
	
	printf("zeichen = %c, Speicherbedarf %i Byte\n", zeichen, sizeof(zeichen));
	zeichen = 0xF6;
	printf("%c > A: %d", zeichen, zeichen > 'A');
	
	
	
	printf("\nLimits\n");
	printf("min. short-Wert: %d\n", SHRT_MIN); // -2^15
	printf("max. short-Wert: %d\n", SHRT_MAX); // 2^15 - 1
	printf("min. int-Wert: %d\n", INT_MIN); // -2^31
	printf("max. int-Wert: %d\n", INT_MAX); // 2^31 - 1
	printf("min. unsigned int-Wert: %u\n", 0); // 0
	printf("max. unsigned int-Wert: %u\n", UINT_MAX); // 2^32 - 1
	printf("min. long-Wert: %ld\n", LONG_MIN); // -2^31
	printf("max. long-Wert: %ld\n", LONG_MAX); // 2^31 - 1
	printf("min. LongLong-Wert: %lld\n", LLONG_MIN); // -2^63
	printf("max. LongLong-Wert: %lld\n", LLONG_MAX); // 2^63 - 1
	printf("min. char-Wert: %d\n", CHAR_MIN); // -2^7
	printf("max. char-Wert: %d\n", CHAR_MAX); // 2^7 - 1
	printf("min. unsigned char-Wert: %d\n", 0); // 0 
	printf("max. unsigned char-Wert: %d\n", UCHAR_MAX); // 2^8 - 1
	
	

	
	return 0;
}
